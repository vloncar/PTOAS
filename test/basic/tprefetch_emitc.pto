// RUN: ptoas %s | FileCheck %s --check-prefix=A3

module attributes {pto.target_arch = "a3"} {
  func.func @tprefetch_emitc(%arg0: !pto.ptr<f16>) {
    %c0 = arith.constant 0 : index
    %c64 = arith.constant 64 : index
    %c16 = arith.constant 16 : index
    %c1 = arith.constant 1 : index
    %tv = pto.make_tensor_view %arg0, shape = [%c64, %c16], strides = [%c16, %c1] : !pto.tensor_view<?x?xf16>
    %part = pto.partition_view %tv, offsets = [%c0, %c0], sizes = [%c16, %c16]
      : !pto.tensor_view<?x?xf16> -> !pto.partition_tensor_view<16x16xf16>
    %tile = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f16, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tprefetch ins(%part : !pto.partition_tensor_view<16x16xf16>)
                  outs(%tile : !pto.tile_buf<loc=vec, dtype=f16, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
}

// A3: TPREFETCH(
